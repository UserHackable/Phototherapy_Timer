#!/usr/bin/env bash
# Flatbed scan + measurement-reference derivatives (Brother MFC on LAN).
#
# Usage:
#   ./scripts/scan-bed list
#   ./scripts/scan-bed scan <name> [options]
#   ./scripts/scan-bed process <png> [options]
#
# Examples:
#   ./scripts/scan-bed scan component-modules
#   ./scripts/scan-bed scan top-frame-front --dpi 600
#   ./scripts/scan-bed process docs/mechanical/foo-scan-600dpi.png
#
# Defaults: eSCL Brother flatbed, 600 DPI color, docs/mechanical/
# Outputs (under --outdir):
#   <name>-scan-<dpi>dpi.png           master (DPI-tagged)
#   <name>-scan-preview.jpg            color thumbnail
#   <name>-scan-preview-contrast.jpg   edge-boosted thumbnail
#
# Scale: 1 mm ≈ dpi/25.4 px (600 DPI → 23.622 px/mm).
# Prefer eSCL — the brother4 SANE backend has segfaulted on full-bed color.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUTDIR="${ROOT}/docs/mechanical"
DPI=600
MODE="Color"
SOURCE="Flatbed"
DEVICE="${SCAN_DEVICE:-escl:http://192.168.1.208:80}"
DESCRIPTION=""
CMD=""
CMD_ARG=""

usage() {
  sed -n '2,22p' "$0" | sed 's/^# \?//'
  exit "${1:-0}"
}

list_devices() {
  echo "SANE devices:"
  scanimage -L 2>/dev/null || true
  echo
  echo "Default DEVICE=${DEVICE}"
  echo "Override: SCAN_DEVICE='...' $0 scan <name>"
  echo "          $0 scan <name> --device 'escl:http://HOST:80'"
}

process_png() {
  local png="$1"
  python3 - "$png" "$DPI" "$DESCRIPTION" <<'PY'
import sys
from pathlib import Path
from PIL import Image, ImageOps, ImageEnhance, PngImagePlugin

png = Path(sys.argv[1])
dpi = int(sys.argv[2])
desc = sys.argv[3] or ""

if not png.is_file():
    sys.exit(f"missing: {png}")

im = Image.open(png)
w, h = im.size
mm_per_px = 25.4 / dpi

stem = png.stem
if "-scan-" in stem:
    prefix = stem.split("-scan-")[0]
else:
    prefix = stem

meta = PngImagePlugin.PngInfo()
meta.add_text(
    "Description",
    desc
    or f"Phototherapy_Timer flatbed scan ({prefix}). "
    f"Brother eSCL, {dpi} DPI. Measurement reference.",
)
meta.add_text("Software", "scripts/scan-bed + Pillow")
meta.add_text("dpi", str(dpi))
meta.add_text("scale_mm_per_px", f"{mm_per_px:.8f}")
im.save(png, format="PNG", dpi=(dpi, dpi), pnginfo=meta, optimize=True)

preview = im.copy()
preview.thumbnail((1500, 2000), Image.Resampling.LANCZOS)
p1 = png.with_name(f"{prefix}-scan-preview.jpg")
preview.save(p1, quality=85, optimize=True)

gray = ImageOps.grayscale(im)
enh = ImageEnhance.Contrast(gray).enhance(2.0)
enh = ImageEnhance.Brightness(enh).enhance(0.95)
enh.thumbnail((1500, 2000), Image.Resampling.LANCZOS)
p2 = png.with_name(f"{prefix}-scan-preview-contrast.jpg")
enh.save(p2, quality=85, optimize=True)

print(f"master:   {png}  ({w}x{h} px @ {dpi} dpi)")
print(f"physical: {w * mm_per_px:.1f} x {h * mm_per_px:.1f} mm")
print(f"scale:    1 mm ≈ {1 / mm_per_px:.3f} px  |  1 in = {dpi} px")
print(f"preview:  {p1}")
print(f"contrast: {p2}")
PY
}

do_scan() {
  local name="$1"
  mkdir -p "$OUTDIR"
  local png="${OUTDIR}/${name}-scan-${DPI}dpi.png"
  local err
  err="$(mktemp)"
  echo "Scanning → ${png}"
  echo "  device=${DEVICE}  source=${SOURCE}  mode=${MODE}  dpi=${DPI}"
  # eSCL often prints a benign HTTP 404 HTML blob after a successful scan
  if ! scanimage -d "$DEVICE" \
      --source "$SOURCE" \
      --mode "$MODE" \
      --resolution "$DPI" \
      --format png \
      -o "$png" 2>"$err"; then
    echo "scanimage failed:" >&2
    cat "$err" >&2 || true
    rm -f "$err"
    exit 1
  fi
  rm -f "$err"
  if [[ ! -s "$png" ]]; then
    echo "empty or missing output: $png" >&2
    exit 1
  fi
  if ! file "$png" | grep -q 'PNG image'; then
    echo "not a PNG: $png" >&2
    file "$png" >&2
    exit 1
  fi
  process_png "$png"
}

# Parse options and subcommand in any order (flags may follow the name).
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage 0 ;;
    --outdir) OUTDIR="$2"; shift 2 ;;
    --dpi) DPI="$2"; shift 2 ;;
    --device) DEVICE="$2"; shift 2 ;;
    --mode) MODE="$2"; shift 2 ;;
    --source) SOURCE="$2"; shift 2 ;;
    --description) DESCRIPTION="$2"; shift 2 ;;
    list)
      CMD=list
      shift
      ;;
    scan)
      CMD=scan
      shift
      if [[ $# -ge 1 && "$1" != -* ]]; then
        CMD_ARG="$1"
        shift
      fi
      ;;
    process)
      CMD=process
      shift
      if [[ $# -ge 1 && "$1" != -* ]]; then
        CMD_ARG="$1"
        shift
      fi
      ;;
    -*)
      echo "unknown option: $1" >&2
      usage 1
      ;;
    *)
      # bare name after scan/process already consumed; leftover = error
      if [[ -z "$CMD_ARG" && -n "$CMD" ]]; then
        CMD_ARG="$1"
        shift
      else
        echo "unexpected argument: $1" >&2
        usage 1
      fi
      ;;
  esac
done

case "${CMD:-}" in
  list) list_devices ;;
  scan)
    [[ -n "$CMD_ARG" ]] || { echo "scan requires a <name>" >&2; usage 1; }
    do_scan "$CMD_ARG"
    ;;
  process)
    [[ -n "$CMD_ARG" ]] || { echo "process requires a <png>" >&2; usage 1; }
    process_png "$CMD_ARG"
    ;;
  *) usage 1 ;;
esac
