# Copy to secrets/wifi.yaml and fill in real passwords.
# secrets/wifi.yaml is gitignored — never commit it.
#
# The module tries known networks from a Wi‑Fi scan and connects to the
# strongest match (by RSSI). Order here is only a tie-breaker.
#
# ---
# - ssid: Ferney
#   password: "your-passphrase"
# - ssid: FamilyGuy
#   password: "other-passphrase"

---
- ssid: ExampleHome
  password: "change-me"
- ssid: ExampleGuest
  password: "change-me-too"
